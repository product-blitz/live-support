# =============================================================================
# Supabase (Postgres + Auth + Realtime)
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# =============================================================================
# 100ms (video/audio/screen share)
# =============================================================================
HMS_APP_ACCESS_KEY=xxx
HMS_APP_SECRET=xxx
HMS_TEMPLATE_ID=xxx
HMS_SUBDOMAIN=your-subdomain.app.100ms.live
# Signing secret from 100ms dashboard → Webhooks. Optional but recommended.
# Without this, /api/hooks/hms rejects all webhooks (401).
HMS_WEBHOOK_SECRET=

# =============================================================================
# Resend (transactional email)
# =============================================================================
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=onboarding@resend.dev

# =============================================================================
# Upstash Redis (rate limiting + idempotency)
# Optional — if unset, rate limits and idempotency are disabled with a warning.
# =============================================================================
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# =============================================================================
# Sentry (errors + traces)
# Optional — if NEXT_PUBLIC_SENTRY_DSN is unset, Sentry is disabled.
# =============================================================================
NEXT_PUBLIC_SENTRY_DSN=
# The following are only needed if you enable sourcemap upload in next.config.js:
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# =============================================================================
# App
# =============================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
CUSTOMER_JWT_SECRET=generate-with-node-crypto-randomBytes-48-hex
